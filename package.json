{
  "name": "safenpm",
  "version": "1.0.0",
  "description": "npm wrapper that sandboxes postinstall scripts, blocks network access, and reports suspicious behavior",
  "keywords": [
    "npm",
    "security",
    "sandbox",
    "supply-chain",
    "postinstall"
  ],
  "license": "MIT",
  "bin": {
    "safenpm": "./dist/cli.js"
  },
  "files": [
    "dist/**/*.js",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "bash test/run-tests.sh"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vercel/node": "^5.6.24",
    "sharp": "^0.34.5",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@upstash/redis": "^1.37.0"
  }
}
